apiVersion: v1
kind: Service
metadata:
  name: debts-bot-db
  namespace: {{ app_namespace }}
spec:
  selector:
    app: debts-bot-db
  ports:
    - name: postgres
      port: 5432
      targetPort: 5432
---
apiVersion: v1
kind: Service
metadata:
  name: debts-bot-db-headless
  namespace: {{ app_namespace }}
spec:
  clusterIP: None
  selector:
    app: debts-bot-db
  ports:
    - name: postgres
      port: 5432
      targetPort: 5432
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: debts-bot-db
  namespace: {{ app_namespace }}
spec:
  serviceName: debts-bot-db-headless
  replicas: 1
  selector:
    matchLabels:
      app: debts-bot-db
  template:
    metadata:
      labels:
        app: debts-bot-db
    spec:
      initContainers:
        - name: fix-permissions
          image: busybox:1.36
          command: ["sh", "-c", "chown -R 999:999 /var/lib/postgresql/data"]
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
      containers:
        - name: postgres
          image: postgres:15-alpine
          ports:
            - containerPort: 5432
              name: postgres
          env:
            - name: POSTGRES_DB
              value: {{ postgres_database | quote }}
            - name: POSTGRES_USER
              value: {{ postgres_user | quote }}
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: debtsapp-env
                  key: SPRING_DATASOURCE_PASSWORD
          readinessProbe:
            exec:
              command: ["sh", "-c", "pg_isready -U {{ postgres_user }} -d {{ postgres_database }}"]
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            exec:
              command: ["sh", "-c", "pg_isready -U {{ postgres_user }} -d {{ postgres_database }}"]
            initialDelaySeconds: 30
            periodSeconds: 15
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class_name | quote }}
        resources:
          requests:
            storage: {{ postgres_storage_size }}
