apiVersion: v1
kind: Service
metadata:
  name: debts-neo4j
  namespace: {{ app_namespace }}
spec:
  selector:
    app: debts-neo4j
  ports:
    - name: http
      port: 7474
      targetPort: 7474
    - name: bolt
      port: 7687
      targetPort: 7687
---
apiVersion: v1
kind: Service
metadata:
  name: debts-neo4j-headless
  namespace: {{ app_namespace }}
spec:
  clusterIP: None
  selector:
    app: debts-neo4j
  ports:
    - name: http
      port: 7474
      targetPort: 7474
    - name: bolt
      port: 7687
      targetPort: 7687
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: debts-neo4j
  namespace: {{ app_namespace }}
spec:
  serviceName: debts-neo4j-headless
  replicas: 1
  selector:
    matchLabels:
      app: debts-neo4j
  template:
    metadata:
      labels:
        app: debts-neo4j
    spec:
      initContainers:
        - name: fix-permissions
          image: busybox:1.36
          command: ["sh", "-c", "chown -R 7474:7474 /data"]
          volumeMounts:
            - name: data
              mountPath: /data
      containers:
        - name: neo4j
          image: neo4j:5-community
          ports:
            - containerPort: 7474
              name: http
            - containerPort: 7687
              name: bolt
          env:
            - name: NEO4J_AUTH
              value: "{{ neo4j_user }}/{{ neo4j_password }}"
          startupProbe:
            tcpSocket:
              port: 7687
            failureThreshold: 30
            periodSeconds: 10
            timeoutSeconds: 5
          readinessProbe:
            tcpSocket:
              port: 7687
            initialDelaySeconds: 20
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 10
          livenessProbe:
            tcpSocket:
              port: 7687
            initialDelaySeconds: 60
            periodSeconds: 20
            timeoutSeconds: 5
            failureThreshold: 6
          volumeMounts:
            - name: data
              mountPath: /data
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class_name | quote }}
        resources:
          requests:
            storage: {{ neo4j_storage_size }}
