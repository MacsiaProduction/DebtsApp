{$APP_DOMAIN} {
    encode gzip

    # Снимаем префикс /api перед проксированием, т.к. бекенд регистрирует роуты без него.
    handle_path /api/* {
        reverse_proxy debts_bot:8080
    }

    handle {
        reverse_proxy debts_frontend:80
    }
}

{$PORTAINER_DOMAIN} {
    encode gzip
    reverse_proxy portainer:9000
}
